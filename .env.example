# ===========================================================================
# .env.example — Nexus Environment Variables Reference
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values BEFORE running docker compose.
#
#   cp .env.example .env
#
# NEVER commit .env to version control. It is in .gitignore.
# This template file (.env.example) is safe to commit — it contains no secrets.
# ===========================================================================

# ---------------------------------------------------------------------------
# DATABASE (TimescaleDB / PostgreSQL)
# ---------------------------------------------------------------------------
# Both Ecto (read model) and EventStore (write model) connect to the same DB.
# Format: ecto://USER:PASSWORD@HOST/DATABASE
DATABASE_URL=ecto://postgres:postgres@db/nexus_prod

# If your EventStore uses a separate database, set this too.
# Defaults to DATABASE_URL if not set.
# EVENT_STORE_URL=ecto://postgres:postgres@db/nexus_events

# Connection pool size per service (tune based on DB server capacity)
POOL_SIZE=10

# Set to "true" if your DB host requires IPv6 connections
# ECTO_IPV6=false

# ---------------------------------------------------------------------------
# PHOENIX APPLICATION
# ---------------------------------------------------------------------------
# Generate with: mix phx.gen.secret
# MUST be at least 64 characters. Never reuse across environments.
SECRET_KEY_BASE=

# Public hostname for the app (used in URL helpers and LiveView sockets)
PHX_HOST=localhost

# HTTP port the app binds to inside the container (mapped in docker-compose)
PORT=4000

# ---------------------------------------------------------------------------
# FX MARKET DATA FEED — Massive (WebSocket)
# ---------------------------------------------------------------------------
# Obtain from https://massive.io — your account API key
MASSIVE_API_KEY=

# Only change this if Massive provides a different endpoint
MASSIVE_WS_URL=wss://socket.massive.com/forex

# ---------------------------------------------------------------------------
# FX MARKET DATA — Polygon.io (if applicable)
# ---------------------------------------------------------------------------
POLYGON_API_KEY=

# ---------------------------------------------------------------------------
# AI BACKEND — Nx / EXLA / Bumblebee
# ---------------------------------------------------------------------------
# Tells EXLA which pre-compiled XLA binary to download at build/startup time.
# Use "cpu" for any machine without a GPU (macOS, standard Linux VMs, CI).
# Use "cuda118" or "cuda120" for NVIDIA GPU servers.
XLA_TARGET=cpu

# ---------------------------------------------------------------------------
# CLUSTERING (optional — leave blank for single-node / local development)
# ---------------------------------------------------------------------------
# DNS_CLUSTER_QUERY=nexus.internal
