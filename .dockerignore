# ===========================================================================
# .dockerignore — Nexus
# Prevents unnecessary files from being sent to the Docker build context.
# Smaller context = faster builds, smaller images.
# ===========================================================================

# Elixir / Mix build artefacts (regenerated in container)
_build/
deps/

# Elixir Language Server
.elixir_ls/
.elixir-tools/

# Static assets (generated by mix assets.deploy inside the build)
priv/static/

# Test artefacts
test/
cover/
*.coverdata

# Logs and temp files
*.log
erl_crash.dump
test_fail.txt
test_failures.log

# Editor config
.vscode/
.idea/
*.iml
*.DS_Store

# Git history (not needed in image)
.git/
.gitignore

# Documentation
*.md
docs/

# CI/CD config (not needed in image)
.github/
.agent/

# Secrets — NEVER send these into the build context
.env
.env.*
!.env.example

# Node (not used in runtime, assets compiled in builder stage)
node_modules/
